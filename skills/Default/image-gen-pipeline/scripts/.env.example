# APIMart
APIMART_API_KEY=your_apimart_api_key

# Aliyun OSS
ALIYUN_OSS_ACCESS_KEY_ID=your_access_key_id
ALIYUN_OSS_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_OSS_BUCKET=your_bucket_name
ALIYUN_OSS_REGION=cn-hangzhou

# Optional
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_PUBLIC_BASE_URL=https://your_bucket_name.oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_PREFIX=generated-images/
IMAGE_GEN_DEFAULT_MODEL=gemini-3.1-flash-image-preview
# Aspect ratio: 1:1 / 3:2 / 2:3 / 4:3 / 3:4 / 16:9 / 9:16 / 5:4 / 4:5 / 21:9 / 1:4 / 4:1 / 1:8 / 8:1
# Also accepts pixel format (e.g. 1792x1024), which is snapped to the nearest supported ratio
IMAGE_GEN_DEFAULT_SIZE=16:9
# Resolution: 0.5K / 1K / 2K / 4K
IMAGE_GEN_DEFAULT_RESOLUTION=1K
IMAGE_GEN_DOWNLOAD_DIR=/tmp/openclaw-image-gen
IMAGE_GEN_POLL_INTERVAL_SECONDS=3
IMAGE_GEN_TIMEOUT_SECONDS=180
